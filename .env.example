# ========================
# 后端环境变量
# ========================

# 后端服务端口（宿主机映射）
PORT=3000

# 监听地址。:: 表示监听所有 IPv4/IPv6 地址（双栈）
HOST=::

# 运行环境：development / production
NODE_ENV=production

# SQLite 数据库文件路径（容器内）。
# 使用 Docker 时会被挂载到 named volume，重启后数据不丢失。
DATABASE_URL=/app/data/dev.sqlite

# CORS 允许来源
# 开发环境可设置为 *；生产环境建议设置为前端域名，如 https://your-domain.com
# 多个来源用逗号分隔，如 https://a.com,https://b.com
# 设置为 false 表示不允许跨域
CORS_ORIGIN=*

# JWT 密钥（生产环境必须设置为强随机字符串，请勿使用默认 dev secret）
JWT_ACCESS_SECRET=your-access-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Token 过期时间
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========================
# 前端构建参数
# ========================

# 前端 API / Socket.IO 基础地址。
# 生产环境建议留空，让前端使用 window.location.origin（配合 Nginx 反向代理）
# 本地开发时指向后端地址：http://localhost:3000
VITE_API_URL=

# ========================
# PostgreSQL 配置（可选）
# ========================

# 如需使用 PostgreSQL，请同时修改后端 data-source.ts 中的数据库配置。
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=change_me
# POSTGRES_DB=zcontrol
# POSTGRES_PORT=5432
# DATABASE_URL=postgresql://postgres:change_me@db:5432/zcontrol
